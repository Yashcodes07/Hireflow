# .env.production
# Copy relevant values to .env for local testing of production config
# On Cloud Run these are set via --set-env-vars and --set-secrets

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="HR Hiring Gateway"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-production-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Google Cloud ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=project-agent-491814
GCP_REGION=us-central1

# ── Vertex AI ─────────────────────────────────────────────────────────────────
VERTEX_MODEL=gemini-2.5-flash

# ── AlloyDB ───────────────────────────────────────────────────────────────────
ALLOYDB_USE_CONNECTOR=true
ALLOYDB_INSTANCE=project-agent-491814:us-central1:hr-alloydb
ALLOYDB_DB_NAME=hrdb
ALLOYDB_DB_USER=hruser
ALLOYDB_DB_PASS=your-alloydb-password

# ── LangSmith ─────────────────────────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls__your-langsmith-key
LANGSMITH_PROJECT=hr-hiring-pipeline
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_TIMEOUT_SECONDS=180
