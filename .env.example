# .env.example — copy to .env and fill in values. Never commit .env to git.

# ── App ───────────────────────────────────────────────
APP_NAME="HR Hiring Gateway"
APP_VERSION="1.0.0"
DEBUG=false

# ── Auth ──────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Comma-separated list of valid static API keys
VALID_API_KEYS=["dev-key-replace-me","another-key"]

# ── LangGraph Agent ───────────────────────────────────
LANGGRAPH_ENDPOINT=http://localhost:8001
AGENT_TIMEOUT_SECONDS=120

# ── Google Cloud ──────────────────────────────────────
GCP_PROJECT_ID=my-gcp-project-id

# AlloyDB — use Cloud SQL connector string for Cloud Run
ALLOYDB_URL=postgresql+asyncpg://user:password@/dbname?host=/cloudsql/project:region:instance

# ── LangSmith observability ───────────────────────────
LANGSMITH_API_KEY=ls__xxxxxxxxxxxx
LANGSMITH_PROJECT=hr-hiring-pipeline

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
